---
import Nav from '../components/Nav.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Strider Settgast — machine learning student & developer based in Florida.',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css" />
  </head>
  <body>
    <Nav />
    <main>
      <slot />
    </main>
    <footer>
      <div class="footer-inner">
        <a href="mailto:stridasaurus@gmail.com">stridasaurus@gmail.com</a>
        <a href="https://github.com/Stridasaurus" target="_blank" rel="noopener noreferrer">GitHub</a>
        <a href="https://www.linkedin.com/in/strider-settgast-70274539b" target="_blank" rel="noopener noreferrer">LinkedIn</a>
      </div>
    </footer>
  </body>
</html>

<style>
  footer {
    border-top: 1px solid var(--border);
    padding: 2rem 0;
    margin-top: 4rem;
  }

  .footer-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    gap: 2rem;
    font-size: 0.875rem;
    color: var(--text-muted);
  }

  .footer-inner a {
    color: var(--text-muted);
  }

  .footer-inner a:hover {
    color: var(--accent);
  }
</style>
