---
import { withBase } from '../utils/url';

const navLinks = [
  { label: 'About', href: '/about' },
  { label: 'Projects', href: '/projects' },
  { label: 'Blog', href: '/blog' },
];

// Astro.url.pathname includes the base path; normalize by stripping a trailing slash.
const currentPath = Astro.url.pathname.replace(/\/$/, '');
---

<nav>
  <div class="nav-inner">
    <a href={withBase('/')} class="nav-name">Strider Settgast</a>
    <ul class="nav-links">
      {navLinks.map(link => {
        const fullHref = withBase(link.href);
        const isActive = currentPath === fullHref || currentPath.startsWith(fullHref + '/');
        return (
          <li>
            <a href={fullHref} class={isActive ? 'active' : ''}>
              {link.label}
            </a>
          </li>
        );
      })}
    </ul>
  </div>
</nav>

<style>
  nav {
    border-bottom: 1px solid var(--border);
    padding: 1.25rem 0;
  }

  .nav-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .nav-name {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--text-primary);
    letter-spacing: -0.01em;
  }

  .nav-name:hover {
    color: var(--accent);
  }

  .nav-links {
    list-style: none;
    display: flex;
    gap: 2rem;
  }

  .nav-links a {
    font-size: 0.875rem;
    color: var(--text-secondary);
  }

  .nav-links a:hover,
  .nav-links a.active {
    color: var(--accent);
  }
</style>
