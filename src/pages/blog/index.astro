---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<BaseLayout title="Blog — Strider Settgast" description="Writing on mathematics, signal processing, and code.">
  <div class="container">
    <header class="page-header">
      <h1>Blog</h1>
      <p>Notes on mathematics, signal processing, and code.</p>
    </header>

    <ol class="post-list">
      {posts.map(post => (
        <li class="post-item">
          <a href={`/blog/${post.slug}`}>
            <div class="post-meta">
              <time datetime={post.data.date.toISOString()}>
                {formatDate(post.data.date)}
              </time>
              {post.data.tags && post.data.tags.length > 0 && (
                <ul class="tags" aria-label="Tags">
                  {post.data.tags.map(tag => <li>{tag}</li>)}
                </ul>
              )}
            </div>
            <h2>{post.data.title}</h2>
            {post.data.description && <p class="description">{post.data.description}</p>}
          </a>
        </li>
      ))}
    </ol>

    {posts.length === 0 && (
      <p class="empty">No posts yet.</p>
    )}
  </div>
</BaseLayout>

<style>
  .container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 2rem;
  }

  .page-header {
    padding: 4rem 0 2.5rem;
    border-bottom: 1px solid var(--border);
  }

  .page-header h1 {
    font-size: 1.5rem;
    font-weight: 500;
    letter-spacing: -0.02em;
    margin-bottom: 0.5rem;
  }

  .page-header p {
    font-size: 0.9375rem;
    color: var(--text-secondary);
  }

  .post-list {
    list-style: none;
    padding-bottom: 4rem;
  }

  .post-item {
    border-bottom: 1px solid var(--border);
  }

  .post-item a {
    display: block;
    padding: 1.75rem 0;
    color: inherit;
  }

  .post-item a:hover h2 {
    color: var(--accent);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.4rem;
  }

  time {
    font-size: 0.8125rem;
    color: var(--text-muted);
  }

  .tags {
    list-style: none;
    display: flex;
    gap: 0.5rem;
  }

  .tags li {
    font-size: 0.75rem;
    color: var(--text-muted);
    border: 1px solid var(--border);
    padding: 0.1rem 0.5rem;
    border-radius: 2px;
  }

  .post-item h2 {
    font-size: 1rem;
    font-weight: 500;
    color: var(--text-primary);
    margin-bottom: 0.3rem;
  }

  .description {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.5;
    max-width: 560px;
  }

  .empty {
    padding: 2rem 0;
    color: var(--text-muted);
    font-size: 0.9375rem;
  }
</style>
