---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { withBase } from '../../utils/url';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<BaseLayout title={`${post.data.title} — Strider Settgast`} description={post.data.description}>
  <div class="container">
    <article>
      <header class="post-header">
        <div class="post-meta">
          <time datetime={post.data.date.toISOString()}>
            {formatDate(post.data.date)}
          </time>
          {post.data.tags && post.data.tags.length > 0 && (
            <ul class="tags" aria-label="Tags">
              {post.data.tags.map(tag => <li>{tag}</li>)}
            </ul>
          )}
        </div>
        <h1>{post.data.title}</h1>
        {post.data.description && <p class="description">{post.data.description}</p>}
      </header>

      <div class="prose">
        <Content />
      </div>
    </article>

    <nav class="back-link">
      <a href={withBase('/blog')}>← All posts</a>
    </nav>
  </div>
</BaseLayout>

<style>
  .container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 2rem;
  }

  .post-header {
    padding: 4rem 0 2.5rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 2.5rem;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.75rem;
  }

  time {
    font-size: 0.8125rem;
    color: var(--text-muted);
  }

  .tags {
    list-style: none;
    display: flex;
    gap: 0.5rem;
  }

  .tags li {
    font-size: 0.75rem;
    color: var(--text-muted);
    border: 1px solid var(--border);
    padding: 0.1rem 0.5rem;
    border-radius: 2px;
  }

  h1 {
    font-size: 1.75rem;
    font-weight: 500;
    letter-spacing: -0.025em;
    line-height: 1.25;
    color: var(--text-primary);
    margin-bottom: 0.75rem;
  }

  .description {
    font-size: 1rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  /* ── Prose ── */
  .prose {
    font-size: 1rem;
    line-height: 1.75;
    color: #333;
    max-width: 680px;
    padding-bottom: 4rem;
  }

  .prose :global(h2) {
    font-size: 1.25rem;
    font-weight: 500;
    margin: 2.5rem 0 0.75rem;
    letter-spacing: -0.015em;
    color: var(--text-primary);
  }

  .prose :global(h3) {
    font-size: 1.05rem;
    font-weight: 500;
    margin: 2rem 0 0.5rem;
    color: var(--text-primary);
  }

  .prose :global(p) {
    margin-bottom: 1.25rem;
  }

  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
  }

  .prose :global(li) {
    margin-bottom: 0.35rem;
  }

  .prose :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .prose :global(a:hover) {
    opacity: 0.8;
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: 2.5rem 0;
  }

  /* ── Code ── */
  .prose :global(pre) {
    background: #f6f8fa;
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 1.25rem;
    overflow-x: auto;
    margin-bottom: 1.5rem;
    font-size: 0.875rem;
    line-height: 1.6;
  }

  .prose :global(code) {
    font-family: 'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, monospace;
    font-size: 0.875em;
  }

  .prose :global(:not(pre) > code) {
    background: #f0f0f0;
    padding: 0.15em 0.4em;
    border-radius: 3px;
  }

  /* ── Math (KaTeX) ── */
  .prose :global(.math-display) {
    overflow-x: auto;
    padding: 0.5rem 0;
    margin: 1.5rem 0;
  }

  .prose :global(.katex-display) {
    overflow-x: auto;
    overflow-y: hidden;
    padding: 0.25rem 0;
  }

  /* ── Back link ── */
  .back-link {
    padding: 2rem 0 4rem;
    border-top: 1px solid var(--border);
  }

  .back-link a {
    font-size: 0.875rem;
    color: var(--text-muted);
  }

  .back-link a:hover {
    color: var(--accent);
  }

  @media (max-width: 600px) {
    h1 {
      font-size: 1.375rem;
    }

    .prose :global(pre) {
      border-radius: 0;
      margin-left: -2rem;
      margin-right: -2rem;
      border-left: none;
      border-right: none;
    }
  }
</style>
