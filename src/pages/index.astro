---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionCard from '../components/SectionCard.astro';
import { withBase } from '../utils/url';
---

<BaseLayout title="Strider Settgast">
  <div class="container">

    <section class="hero">
      <div class="headshot" aria-label="Headshot placeholder">
        <svg viewBox="0 0 80 80" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <circle cx="40" cy="40" r="40" fill="#e0e0e0" />
          <circle cx="40" cy="32" r="13" fill="#c0c0c0" />
          <ellipse cx="40" cy="70" rx="22" ry="16" fill="#c0c0c0" />
        </svg>
      </div>

      <div class="hero-text">
        <h1>Strider Settgast</h1>
        <p class="tagline">Physics undergraduate &amp; computational researcher</p>
        <p class="bio">
          I study physics and computational mathematics at the Florida Institute
          of Technology, where I lead research localizing magnetohydrodynamic
          wave sources from ground-based magnetometer data. I work where signal
          processing, inverse problems, and machine learning meet.
        </p>
      </div>
    </section>

    <section class="sections" aria-label="Site sections">
      <SectionCard
        title="About"
        description="Education, research, and what I'm currently working on."
        href={withBase('/about')}
      />
      <SectionCard
        title="Projects"
        description="Research code and computational projects, with writeups."
        href={withBase('/projects')}
      />
      <SectionCard
        title="Blog"
        description="Notes on physics, mathematics, and computation."
        href={withBase('/blog')}
      />
    </section>

  </div>
</BaseLayout>

<style>
  .container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 2rem;
  }

  .hero {
    display: flex;
    align-items: flex-start;
    gap: 2rem;
    padding: 4rem 0 3.5rem;
  }

  .headshot {
    width: 80px;
    height: 80px;
    flex-shrink: 0;
  }

  .headshot svg {
    width: 100%;
    height: 100%;
    border-radius: 50%;
  }

  .hero-text h1 {
    font-size: 1.5rem;
    font-weight: 500;
    color: var(--text-primary);
    letter-spacing: -0.02em;
    line-height: 1.2;
    position: relative;
    display: inline-block;
  }

  .hero-text h1::after {
    content: '';
    display: block;
    height: 2px;
    width: 100%;
    background: var(--accent);
    margin-top: 5px;
  }

  .tagline {
    font-size: 0.9375rem;
    color: var(--text-secondary);
    margin-top: 0.625rem;
    margin-bottom: 1rem;
  }

  .bio {
    font-size: 0.9375rem;
    color: #444444;
    line-height: 1.7;
    max-width: 500px;
  }

  .sections {
    border-top: 1px solid var(--border);
    padding-bottom: 4rem;
  }

  @media (max-width: 480px) {
    .hero {
      flex-direction: column;
      gap: 1.5rem;
      padding: 2.5rem 0 2.5rem;
    }
  }
</style>
